# Client-side (bundled into the browser build — prefix with NEXT_PUBLIC_)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000

# Optional TURN server for NAT traversal (Xirsys, Metered, or self-hosted Coturn)
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=

# Server-side only
ROOM_EXPIRY_MS=1800000
MAX_ROOMS=1000
RATE_LIMIT_EVENTS_PER_SECOND=10

# Restrict WebSocket CORS in production (set to your Railway/Fly.io domain)
CORS_ORIGIN=*

# Railway injects PORT automatically; set locally if needed
PORT=3000
